# 认证
APP_PASSWORD=your_password
JWT_SECRET=your_jwt_secret

# Cherry Studio API（本地）
CHERRY_STUDIO_URL=http://localhost:8002/v1
CHERRY_MODEL=default

# SMTP 邮件
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=your_password
MAIL_TO=receiver@email.com

# frp 内网穿透（启动后端时自动启动 frpc）
FRPC_ENABLED=false
FRPC_BIN=D:\frp\frpc.exe
FRPC_CONFIG=windows/frpc/frpc.toml

# 路径
UPLOAD_DIR=D:\whisper-tools\uploads
ARCHIVE_DIR=D:\whisper-archive
DB_PATH=D:\whisper-tools\whisper_tools.db
